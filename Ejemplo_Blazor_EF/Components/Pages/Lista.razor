@page "/"
@rendermode InteractiveServer
@inject ListaViewModel VM

<div class="contenedor-pagina">
   <h1>@VM.Titulo</h1>
</div>
@if (VM.Reuniones.Count == 0)
{
   <p>No hay reuniones.</p>
}
else
{
   <div class="contenedor-pagina">
      <div class="header-acciones">
        <input type="text" class="input-busqueda" placeholder="Buscar reunión..." @bind="VM.TextoBusqueda" />
        <button class="btn-buscar" @onclick="VM.Filtrar">buscar</button>
        <button class="btn-agregar" @onclick="VM.IrAFormulario">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
               <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
            </svg>
        </button>
      </div>
      <table class="table-reuniones">
         <thead>
            <tr>
               <th>Resumen</th>
               <th>Virtual</th>
               <th>Acciones</th>
            </tr>
         </thead>
         <tbody>
            @foreach(var r in VM.ReunionesFiltradas)
            {
               <tr id="@r.Id">
                  <td class="col-resumen">@(r.Desc?.Length > 30 ? r.Desc[..30] + "..." : r.Desc)</td>
                  <td class="col-virtual">@(r.Virtual ? "SI" : "NO")</td>
                  <td class="col-acciones">
                     <button class="btn-icono btn-borrar" @onclick="() => VM.PrepararBorrado(r.Id)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-file-minus" viewBox="0 0 16 16">
                           <path d="M5.5 8a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1H6a.5.5 0 0 1-.5-.5"/>
                           <path d="M4 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm0 1h8a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1"/>
                        </svg>
                     </button>
                     <button class="btn-icono btn-editar" @onclick="() => VM.SeleccionarParaEditar(r)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                           <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                           <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                        </svg>
                     </button>
                     <button class="btn-icono btn-detalle" @onclick="() => VM.IrADetalle(r.Id)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                           <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                        </svg>
                     </button>
                  </td>
               </tr>
            }
         </tbody>
      </table>
   </div>
   <ModalEdit visible="VM.ModalVisible" reunion="VM.ReunionSelec" 
              OnGuardar="VM.GuardarEdicion" OnCerrar="() => VM.ModalVisible = false" />
}
@if (VM.MostrarConfirm)
{
   <div class="confirm-backdrop">
      <div class="confirm-box">
         <p>¿Seguro que querés borrar esta reunión?</p>
         <div class="confirm-footer">
            <button class="btn-secondary" @onclick="VM.CancelarBorrado">Cancelar</button>
            <button class="btn-danger" @onclick="VM.ConfirmarBorrado">Borrar</button>
         </div>
      </div>
   </div>
}
@code { protected override void OnInitialized() => VM.CargarReuniones(); }