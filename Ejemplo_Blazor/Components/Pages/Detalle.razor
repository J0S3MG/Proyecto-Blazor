@page "/detalle/{Id:int}"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IReunionRepository Repo

<div class="contenedor-detalle">
    <div class="contenedor-titulo">
        <h1>@Titulo</h1>
    </div>
    <div class="form-group">
        <label class="label-principal">Descripción (500 letras)</label>
        <textarea class="caja-texto" @bind="reunion.Desc" maxlength="500"></textarea>
        <div class="contador-letras">
            @(reunion.Desc?.Length ?? 0) letras
        </div>
    </div>
    <div class="opcion-virtual">
        <label>¿Es virtual?</label>
        <input type="checkbox" @bind="reunion.Virtual" class="check-virtual" />
    </div>
    <div class="footer-detalle">
        <button class="btn-confirmar" @onclick="OnVolver_Clicked">Volver</button>
        <button class="btn-icono btn-editar" @onclick="() => OnEdit_Clicked(reunion)">
            <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
            </svg>
        </button>
    </div>
</div>
<ModalEdit visible="modalVisible" reunion="reunionSelec" 
              OnGuardar="HandleGuardar" OnCerrar="() => modalVisible = false" />
@code 
{
    private string Titulo = "Detalle Reunion";
    [Parameter] public int Id { get; set; }
    [Parameter] public Reunion? reunion { get; set; }

    protected override void OnInitialized()
    {
        reunion = Repo.GetById(Id);
    }

    private void OnVolver_Clicked()
    {
        Nav.NavigateTo("/");
    }

    private bool modalVisible = false;
    private Reunion? reunionSelec;

   private void OnEdit_Clicked(Reunion r)
   {
      reunionSelec = r;
      modalVisible = true;
   }

   private void HandleGuardar(Reunion editada)
   {
      Repo.Update(editada);
      modalVisible = false;
   }
}