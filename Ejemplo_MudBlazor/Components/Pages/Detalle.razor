@page "/detalle/{Id:int}"
@rendermode InteractiveServer
@inject DetalleViewModel VM

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudPaper Elevation="3" Class="pa-6">   
        <MudText Typo="Typo.h4" GutterBottom="true">@VM.Titulo</MudText>

        <MudTextField T="string" Label="Descripción (500 letras)" Variant="Variant.Outlined" 
                      Lines="5" @bind-Value="VM.Reunion.Desc" 
                      Counter="500" MaxLength="500" Immediate="true" Class="mt-4" />

        <MudCheckBox T="bool" @bind-Value="VM.Reunion.Virtual" Label="¿Es virtual?" Color="Color.Primary" Class="mt-2" />

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowBack" 
                       OnClick="VM.VolverAtras"> Volver </MudButton>

            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                           Color="Color.Secondary" Variant="Variant.Filled"
                           OnClick="() => VM.SeleccionarParaEditar(VM.Reunion)" />
        </MudStack>
    </MudPaper>
</MudContainer>
@code 
{ 
    [Parameter] public int Id { get; set; }
    protected override void OnInitialized() => VM.CargarReunion(Id); 
}