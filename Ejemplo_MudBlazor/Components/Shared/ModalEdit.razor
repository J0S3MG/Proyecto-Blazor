@rendermode InteractiveServer

<MudDialog IsVisible="visible" IsVisibleChanged="CerrarDesdeOverlay" Options="_options">
    <TitleContent>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2"/> Editar reunión
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Cerrar" Size="Size.Small" />
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (copia != null)
        {
            <MudStack Spacing="4">
                <MudTextField T="string" 
                              Label="Descripción" 
                              @bind-Value="copia.Desc" 
                              Variant="Variant.Outlined" 
                              Lines="3" 
                              Counter="500"
                              MaxLength="500"
                              Immediate="true"
                              Placeholder="¿De qué trata la reunión?" />

                <MudCheckBox T="bool" 
                             @bind-Value="copia.Virtual" 
                             Label="Esta reunión es virtual" 
                             Color="Color.Primary" />
            </MudStack>
        }
        else
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cerrar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="Guardar"
                   Disabled="@(copia == null)">
            Guardar Cambios
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool visible { get; set; }
    [Parameter] public Reunion? reunion { get; set; }
    [Parameter] public EventCallback<Reunion> OnGuardar { get; set; }
    [Parameter] public EventCallback OnCerrar { get; set; }

    private Reunion? copia;

    private DialogOptions _options = new() { 
        CloseOnEscapeKey = true, 
        MaxWidth = MaxWidth.Small, 
        FullWidth = true,
        BackdropClick = true
    };

    protected override void OnParametersSet()
    {
        // Solo actualizamos la copia cuando se abre el modal con una reunión válida
        if (visible && reunion != null)
        {
            copia = new Reunion(reunion.Id, reunion.Desc, reunion.Virtual);
        }

        if (!visible)
        {
            copia = null;
        }
    }

    private async Task Guardar()
    {
        if (copia != null)
            await OnGuardar.InvokeAsync(copia);
    }

    private async Task Cerrar()
    {
        await OnCerrar.InvokeAsync();
    }

    private async Task CerrarDesdeOverlay(bool nuevoEstado)
    {
        if (!nuevoEstado)
            await OnCerrar.InvokeAsync();
    }
}